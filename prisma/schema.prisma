  @@map("dashboard_cache")
}

// Finance tables
model FeeStructure {
  id       BigInt  @id @default(autoincrement())
  schoolId BigInt? @map("school_id")
  classId  BigInt  @map("class_id")
  termId   BigInt  @map("term_id")
  item     String  @db.VarChar(120)
  amount   Decimal @db.Decimal(14, 2)

  // Relations
  class Class @relation(fields: [classId], references: [id])
  term  Term  @relation(fields: [termId], references: [id])

  @@map("fee_structures")
}

model StudentFeeItem {
  id       BigInt  @id @default(autoincrement())
  studentId BigInt @map("student_id")
  termId   BigInt  @map("term_id")
  item     String  @db.VarChar(120)
  amount   Decimal @db.Decimal(14, 2)
  discount Decimal @default(0) @db.Decimal(14, 2)
  paid     Decimal @default(0) @db.Decimal(14, 2)

  // Relations
  student Student @relation(fields: [studentId], references: [id])
  term    Term    @relation(fields: [termId], references: [id])

  @@map("student_fee_items")
}

model FeePayment {
  id            BigInt    @id @default(autoincrement())
  studentId     BigInt    @map("student_id")
  termId        BigInt    @map("term_id")
  walletId      BigInt    @map("wallet_id")
  amount        Decimal   @db.Decimal(14, 2)
  method        String?   @db.VarChar(30)
  paidBy        String?   @map("paid_by") @db.VarChar(150)
  payerContact  String?   @map("payer_contact") @db.VarChar(50)
  reference     String?   @db.VarChar(120)
  receiptNo     String?   @map("receipt_no") @db.VarChar(40)
  ledgerId      BigInt?   @map("ledger_id")
  createdAt     DateTime  @default(now()) @map("created_at")

  // Relations
  student Student @relation(fields: [studentId], references: [id])
  term    Term    @relation(fields: [termId], references: [id])

  @@map("fee_payments")
}

model ClassResult {
  id           BigInt   @id @default(autoincrement())
  studentId    BigInt   @map("student_id")
  classId      BigInt   @map("class_id")
  subjectId    BigInt   @map("subject_id")
  termId       BigInt?  @map("term_id")
  resultTypeId BigInt   @map("result_type_id")
  score        Decimal? @db.Decimal(5, 2)
  grade        String?  @db.VarChar(10)
  remarks      String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    String?  @map("updated_at") @db.VarChar(255)

  // Relations
  student Student @relation(fields: [studentId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  term    Term?   @relation(fields: [termId], references: [id])

  @@unique([studentId, classId, subjectId, termId, resultTypeId], name: "uq_class_result")
  @@map("class_results")
}